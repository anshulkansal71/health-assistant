# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/health_assistant

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# AWS S3 (prescriptions are uploaded as private objects; presigned URLs are
# generated on demand for short-lived access)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-private-prescriptions-bucket
